{
  "name": "aws-cost-optimizer",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "backend": "python3 -m uvicorn api.main:app --reload --host 0.0.0.0 --port 8000",
    "frontend": "npm --prefix frontend run dev",
    "dev": "concurrently -k -n backend,frontend -c cyan,magenta \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}